# ============================================
# Supabase Frontend Configuration
# ============================================
# Get these from: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# Supabase Database Configuration (for Serverless APIs)
# ============================================
# Get connection string from: Supabase > Settings > Database > Connection Pooler
# Choose "Node.js" for the connection string
# Replace YOUR_PASSWORD with your database password
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:6543/postgres?schema=public

# ============================================
# Supabase Auth Configuration (for Serverless API validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# JWT Configuration (for authentication)
# IMPORTANT: Generate strong random strings in production!
# ============================================
JWT_SECRET=your-jwt-secret-key-min-32-characters-recommended
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-characters-recommended
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ============================================
# Node Environment
# ============================================
NODE_ENV=development
PORT=3002
